{
  "name": "veronum-site",
  "version": "0.1.0",
  "private": true,
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "electron:dev": "cross-env NODE_ENV=development concurrently \"npm run dev\" \"wait-on http://localhost:3000 && npm run electron:compile && electron dist/electron/main.js\"",
    "electron:build": "npm run build && npm run electron:compile && electron-builder",
    "electron:start": "npm run electron:compile && electron dist/electron/main.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "@vercel/blob": "^2.4.0",
    "@vercel/sandbox": "^2.1.1",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "next": "^15.4.0",
    "posthog-js": "^1.386.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^17.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.veronum.site",
    "productName": "Veronum",
    "files": [
      "dist/**/*",
      ".next/**/*",
      "out/**/*",
      "public/**/*"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
